DATABASE_URL="postgresql://postgres:password@localhost:5432/recovera?schema=public"
GITHUB_ID= 
GITHUB_SECRET= 
NEXTAUTH_SECRET="recovera_super_secret_key_12345"
NEXTAUTH_URL="http://localhost:3000"

ENCRYPTION_KEY= 
INGEST_API_URL="https://expedited-target-proactive.ngrok-free.dev/api/ingest/logs"
## ngrok in the system to get the ingest api url

## ── Gemini AI (Primary LLM + Embeddings for Step 4) ──────────────────────────
GEMINI_API_KEY=                    # Required: get from https://aistudio.google.com/app/apikey
GEMINI_MODEL=gemini-1.5-flash      # Optional: defaults to gemini-1.5-flash

## ── Groq (Fallback LLM for reranking) ────────────────────────────────────────
GROQ_API_KEY=                      # Required for fallback: get from https://console.groq.com
GROQ_MODEL=llama-3.1-8b-instant    # Optional: defaults to llama-3.1-8b-instant

## ── GitHub Webhook (Step 4 incremental indexing) ─────────────────────────────
GITHUB_WEBHOOK_SECRET=             # Required: set this when registering your GitHub App webhook

## ── Agent Flags ────────────────────────────────────────────────────────────── 
AGENT_MOCK=false                   # Set to "true" to skip real LLM calls during local dev/testing
