// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  cloudCredentials CloudCredential[]
  integrations     Integration[]
  repositories     Repository[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CloudCredential {
  id              String        @id @default(cuid())
  userId          String
  provider        String
  label           String?
  accessKeyId     String        @db.Text
  secretAccessKey String        @db.Text
  region          String
  roleArn         String?       @db.Text
  sessionToken    String?       @db.Text
  isActive        Boolean       @default(true)
  lastVerifiedAT  DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  integrations    Integration[]

  @@unique([userId, provider, label])
}

model Integration {
  id           String            @id @default(cuid())
  userId       String
  credentialId String
  provider     String
  s3BucketName String?
  firehoseArn  String?
  status       String
  errorMessage        String?
  provisioningDetails String?  @db.Text // JSON: step-by-step provisioning status with resource names
  lastSyncAt          DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentials  CloudCredential   @relation(fields: [credentialId], references: [id])
  mappings     InstanceMapping[]

  @@unique([userId, provider, credentialId])
}

model InstanceMapping {
  id            String   @id @default(cuid())
  integrationId String
  repositoryId  String?
  repoFullName  String // "user/payment-api"
  logGroupName  String // "/aws/eks/cluster/containers"
  resourceId    String? // instance ID, service ARN, or ECR image name
  resourceType  String // "ec2" | "ecs" | "eks" | "lambda" | "log_group"
  resourceLabel String? // friendly name from tags
  confidence    Float    @default(0) // 0.0 to 1.0
  source        String   @default("auto") // "auto" | "manual"
  status        String   @default("pending") // "pending" | "confirmed" | "ignored"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  repository  Repository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)

  @@unique([integrationId, logGroupName, resourceId])
}

model Repository {
  id            String   @id @default(cuid())
  userId        String
  fullName      String // "user/repo"
  name          String
  description   String?
  stars         Int      @default(0)
  language      String?
  isPrivate     Boolean  @default(false)
  htmlUrl       String
  defaultBranch String   @default("main")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  mappings  InstanceMapping[]
  incidents Incident[]

  @@unique([userId, fullName])
}

model Incident {
  id           String   @id @default(cuid())
  repositoryId String
  fingerprint  String
  title        String
  severity     String // "low" | "medium" | "high" | "critical"
  status       String // "open" | "investigating" | "mitigated" | "resolved" | "ignored"
  firstSeenAt  DateTime @default(now())
  lastSeenAt   DateTime @default(now())
  eventCount   Int      @default(1)
  confidence   Float    @default(1.0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  repository    Repository      @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  events        IncidentEvent[]
  patches       PatchArtifact[]
  actions       IncidentAction[]
  rcaVersions   IncidentRca[]

  @@unique([repositoryId, fingerprint])
  @@index([status, severity])
}

model IncidentRca {
  id              String   @id @default(cuid())
  incidentId      String
  rcaPayload      String   @db.Text
  version         Int      @default(1)
  createdAt       DateTime @default(now())

  incident        Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, version])
}

model IncidentEvent {
  id               String   @id @default(cuid())
  incidentId       String
  eventId          String   @unique
  rawExcerpt       String   @db.Text
  stackTop         String?  @db.Text
  detectedAt       DateTime @default(now())
  processingStatus String   @default("pending") // "pending" | "processed" | "failed"

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, detectedAt])
}

model DetectionAudit {
  id            String   @id @default(cuid())
  eventId       String   @unique
  engine        String // "rule" | "llm"
  label         String
  confidence    Float
  explanation   String?  @db.Text
  reportPayload String?  @db.Text // Store JSON stringified DiagnosticReport
  createdAt     DateTime @default(now())

  @@index([eventId])
}

model PatchArtifact {
  id               String   @id @default(cuid())
  incidentId       String
  patchDiff        String   @db.Text
  changeSummary    String   @db.Text
  riskScore        Float
  validationStatus String   @default("pending") // pending, passed, failed
  validationLogs   String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
}

model IncidentAction {
  id               String   @id @default(cuid())
  incidentId       String
  actionType       String   // "open_pr", etc.
  status           String   // "pending", "opened", "failed", "merged", "closed"
  requiresApproval Boolean  @default(false)
  branchName       String?
  commitSha        String?
  prUrl            String?
  failureReason    String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  incident         Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
}

model SafetyAuditLog {
  id              String   @id @default(cuid())
  incidentId      String
  actionType      String   // "fix_generation", "pr_creation"
  decision        String   // "ALLOW_AUTO_PR", "REQUIRE_HUMAN_APPROVAL", "BLOCK_AND_ALERT"
  reasonCodes     String   // Comma-separated list of reasons (e.g. "HIGH_RISK_DOMAIN, LOW_CONFIDENCE")
  riskScore       Float
  details         String?  @db.Text
  createdAt       DateTime @default(now())

  @@index([incidentId, createdAt])
}
